# 复制到 `.env` 文件并填写。`docker compose up -d` 命令会通过 `env_file` 文件读取它。

# === 认证 ===

# 用于 /admin 会话的 Cookie 签名密钥。如果未设置/为空，服务器
# 会在启动时生成一个随机密钥（并记录警告）——然后会话
# 将在重启后失效。请在生产环境中设置一个稳定的值：
#   openssl rand -hex 32
SESSION_SECRET_KEY=636d6260e6dc58c9e8dec39a03df97da4e8c49e3de0f79521b82a4bdb0d4db20

# 仅在首次启动时使用 — 当 `users` 表为空时调用 `init_db()`
# 使用此密码和 `must_change_pw=1` 初始化 `admin` 帐户。
# 管理员登录一次并更改密码后，此变量
# 将被忽略；保持设置状态无效。
ADMIN_INITIAL_PASSWORD=123456

# === 桶存储 ===

# 用于暂存和生产环境对象存储的存储桶提供程序。
# 值：none / oss（阿里云开源软件） / tos（Volcengine TOS）。
# 设置为 oss 或 tos 时，还需要取消注释 docker-compose.yml 中的凭据绑定挂载，并在 app/storage/credentials.py 中填写相关信息。
STORAGE_PROVIDER=tos

# === Pipeline ===

# 并发编码任务（每个任务都是一个独立的 ffmpeg 子进程；ffmpeg 本身
# 是多线程的）。>= 1。仅当主机有空闲 CPU 核心时才引发异常。
PIPELINE_CONCURRENCY=2

# 管理员预览播放器的默认分辨率（540p / 720p / 1080p）。
# SDK 响应始终包含所有三个分辨率；这只会影响管理员 /admin 页面的播放内容。
DEFAULT_LADDER=720p

# === 业务服务器同步 ===

# 当未设置 BUSINESS_SYNC_BASE_URL 时，/admin/sync 用户界面将被隐藏，并且
# 同步端点将返回 503 错误。要启用此功能，请设置以下两个变量。
BUSINESS_SYNC_BASE_URL=https://agent.coocent.com/drama
BUSINESS_SYNC_API_KEY=Coocent@Video
BUSINESS_SYNC_TIMEOUT=30
