# Copy to `.env` and fill in. `docker compose up -d` reads it via `env_file`.

# === Required ===

# Cookie signing secret for /admin sessions. MUST be stable across restarts;
# regenerating logs every operator out. Generate with:
#   openssl rand -hex 32
SESSION_SECRET_KEY=

# Required on first boot only — when the `users` table is empty `init_db()`
# bootstraps the `admin` account with this password and `must_change_pw=1`.
# Once the admin has logged in once and changed their password this variable
# is ignored; leaving it set has no effect.
ADMIN_INITIAL_PASSWORD=changeme

# === Bucket storage ===

# Bucket provider for staging + prod object storage.
# Values: none / oss (Aliyun OSS) / tos (Volcengine TOS).
# When set to oss or tos, also uncomment the credentials bind mount in
# docker-compose.yml and fill in app/storage/credentials.py.
STORAGE_PROVIDER=none

# === Pipeline ===

# Concurrent encode jobs (each is its own ffmpeg subprocess; ffmpeg itself
# is multi-threaded). >= 1. Raise only if the host has spare CPU cores.
PIPELINE_CONCURRENCY=2

# Default ladder rung for the admin preview player (540p / 720p / 1080p).
# SDK responses always carry all three rungs; this only affects what the
# admin's /admin page plays back.
DEFAULT_LADDER=720p

# === Business-server sync (optional) ===

# When BUSINESS_SYNC_BASE_URL is unset, /admin/sync UI is hidden and the
# sync endpoints return 503. To enable, set both vars below.
# BUSINESS_SYNC_BASE_URL=http://business.internal:9000
# BUSINESS_SYNC_API_KEY=
# BUSINESS_SYNC_TIMEOUT=30
